# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# GNews API — https://gnews.io
GNEWS_API_KEY=your-gnews-api-key
GNEWS_API_URL=https://gnews.io/api/v4

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# HuggingFace Hub model repos (set after uploading weights)
HF_REPO_DISTILBERT=your-username/distilbert-fakenews
HF_REPO_ROBERTA=your-username/roberta-fakenews
HF_REPO_XLNET=your-username/xlnet-fakenews

# CORS — add your Vercel frontend URL here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# App
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO
